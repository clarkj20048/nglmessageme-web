# MongoDB Connection String
# Get this from MongoDB Atlas (https://www.mongodb.com/atlas/database)
# Format: mongodb+srv://username:password@cluster.mongodb.net/ngl?retryWrites=true&w=majority
MONGO_URI=your_mongodb_connection_string_here

# Client Origin (your Vercel frontend URL)
CLIENT_ORIGIN=https://nglmessagemeweb.vercel.app

# JWT Secret (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your_jwt_secret_here

# Server Port (default: 5000)
PORT=5000

# Optional: Admin credentials for seeding
ADMIN_EMAIL=admin@ngl.com
ADMIN_PASSWORD=admin123

